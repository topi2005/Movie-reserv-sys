generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum ReservationStatus {
  CONFIRMED
  CANCELLED
}

enum Genre {
  ACTION
  COMEDY
  DRAMA
  HORROR
  THRILLER
  ROMANCE
  SCIENCE_FICTION
  ANIMATION
  DOCUMENTARY
  FANTASY
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  name         String
  role         Role          @default(USER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reservations Reservation[]

  @@map("users")
}

// ─────────────────────────────────────────────
// MOVIE
// ─────────────────────────────────────────────

model Movie {
  id          String     @id @default(cuid())
  title       String
  description String
  posterUrl   String?
  durationMin Int        // runtime in minutes
  genre       Genre
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  showtimes   Showtime[]

  @@map("movies")
}

// ─────────────────────────────────────────────
// HALL  (cinema hall / screen)
// ─────────────────────────────────────────────

model Hall {
  id        String     @id @default(cuid())
  name      String     @unique   // e.g. "Hall A", "IMAX 1"
  rows      Int                  // e.g. 10
  columns   Int                  // e.g. 15 → 150 seats
  createdAt DateTime   @default(now())
  showtimes Showtime[]

  @@map("halls")
}

// ─────────────────────────────────────────────
// SHOWTIME
// ─────────────────────────────────────────────

model Showtime {
  id           String        @id @default(cuid())
  movieId      String
  hallId       String
  startsAt     DateTime
  endsAt       DateTime
  priceAmount  Decimal       @db.Decimal(10, 2)
  priceCurrency String       @default("USD")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  movie        Movie         @relation(fields: [movieId], references: [id], onDelete: Cascade)
  hall         Hall          @relation(fields: [hallId], references: [id])
  seats        Seat[]
  reservations Reservation[]

  // No two showtimes in the same hall can overlap
  @@unique([hallId, startsAt])
  @@index([startsAt])
  @@map("showtimes")
}

// ─────────────────────────────────────────────
// SEAT
// One row per physical seat per showtime.
// Created when a showtime is created (via seed/trigger logic in the service layer).
// ─────────────────────────────────────────────

model Seat {
  id          String       @id @default(cuid())
  showtimeId  String
  row         Int          // 1-based
  column      Int          // 1-based
  label       String       // e.g. "A1", "B12"
  isReserved  Boolean      @default(false)
  version     Int          @default(0)  // optimistic locking

  showtime    Showtime     @relation(fields: [showtimeId], references: [id], onDelete: Cascade)
  reservation Reservation?

  // Each seat position is unique within a showtime
  @@unique([showtimeId, row, column])
  @@index([showtimeId, isReserved])
  @@map("seats")
}

// ─────────────────────────────────────────────
// RESERVATION
// ─────────────────────────────────────────────

model Reservation {
  id          String            @id @default(cuid())
  userId      String
  showtimeId  String
  seatId      String            @unique   // one reservation per seat
  status      ReservationStatus @default(CONFIRMED)
  amountPaid  Decimal           @db.Decimal(10, 2)
  currency    String            @default("USD")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user        User              @relation(fields: [userId], references: [id])
  showtime    Showtime          @relation(fields: [showtimeId], references: [id])
  seat        Seat              @relation(fields: [seatId], references: [id])

  @@index([userId])
  @@index([showtimeId])
  @@map("reservations")
}