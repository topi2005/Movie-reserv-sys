###############################################################
# Movie Reservation Service – Environment Configuration
###############################################################

# ── Database ──────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://cinema:cinema_secret@localhost:5432/movie_reservation"
# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ── File Uploads ──────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_MAX=100

# ── Admin seed ────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@cinema.com
SEED_ADMIN_PASSWORD=Admin@1234
SEED_ADMIN_NAME=System Admin